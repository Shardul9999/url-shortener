DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/urlshortener
REDIS_URL=redis://cache:6379/0
SECRET_KEY=change-me-in-production
BASE_URL=http://localhost:8000

# Rate limits (requests per IP per minute)
RATE_LIMIT_PER_MINUTE=100
REDIRECT_RATE_LIMIT_PER_MINUTE=1000

# CORS: comma-separated list of allowed origins (leave empty if no browser frontend)
# Example: ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=

CACHE_TTL_SECONDS=3600
